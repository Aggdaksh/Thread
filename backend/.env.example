# -----------------------------------------------------------------------------
# NEVER COMMIT REAL VALUES — This file is a template only.
# Copy to .env and set real values locally; keep .env out of version control.
# Production: inject via Render/secret manager; never commit DB_URI, JWT_SECRET,
# REFRESH_PEPPER, ROOT_ADMIN_PASSWORD, or any credential.
# -----------------------------------------------------------------------------
# REQUIRED IN PRODUCTION (NODE_ENV=production): NODE_ENV, PORT, JWT_SECRET, DB_URI,
# REFRESH_PEPPER, CORS_ORIGIN or CORS_ORIGINS, WS_PATH, ROOT_ADMIN_EMAIL,
# ROOT_ADMIN_PASSWORD. COOKIE_DOMAIN can stay blank for default Vercel + Render URLs.
# -----------------------------------------------------------------------------
NODE_ENV=development
# PORT — HTTP listen port. Local frontend proxy expects 8000 unless VITE_BACKEND_PORT is changed.
PORT=8000
# JWT_SECRET — JWT signing secret. Example prod: 32+ char random string. SECRET.
JWT_SECRET=
# REFRESH_PEPPER — Pepper for refresh token hashing. Required in production (non-empty). SECRET.
REFRESH_PEPPER=
# DB_URI — MongoDB connection. SECRET. Set only in .env or server env; never commit real values.
# Example (Atlas): mongodb+srv://<USER>:<PASSWORD>@<HOST>/<DB>?retryWrites=true&w=majority
# Local dev: mongodb://127.0.0.1:27017/mychat (set ALLOW_LOCAL_DB=true).
DB_URI=mongodb+srv://<USER>:<PASSWORD>@<HOST>/Thread?retryWrites=true&w=majority
# DB_NAME — Database name used by the app. Keep exact case as Atlas DB name.
DB_NAME=Thread
# Mongo network tuning. Render/Atlas deploys can prefer IPv4 to avoid DNS/IPv6/TLS ambiguity.
MONGO_NETWORK_FAMILY=4
MONGO_SERVER_SELECTION_TIMEOUT_MS=30000
MONGO_CONNECT_TIMEOUT_MS=20000
# ALLOW_LOCAL_DB — Set to true in development to allow localhost/127.0.0.1 or mongodb:// (non-SRV). Required for local Mongo.
ALLOW_LOCAL_DB=false
# ROOT_ADMIN_EMAIL — Email of the root admin; this user is ensured at startup (bootstrap) with role ADMIN. Case-insensitive. Use a placeholder locally; set real value in server env only.
ROOT_ADMIN_EMAIL=admin@example.com
# ROOT_ADMIN_PASSWORD — Password for root admin bootstrap. Required when ROOT_ADMIN_EMAIL is set. SECRET. Used only at startup to create/update root user in Mongo.
ROOT_ADMIN_PASSWORD=
# DISALLOW_FILE_STORE — Set to true to enforce Atlas-only; any require() of file-backed stores (user/room/reports/warnings) will throw.
DISALLOW_FILE_STORE=true
# COOKIE_DOMAIN — Controls cookie domain scope for browser JWT. Example prod: .example.com. NON-SECRET. Injected: EC2 env / PM2.
COOKIE_DOMAIN=
# CORS_ORIGIN — Single allowed CORS origin for frontend. Example prod: https://app.example.com. In production, at least one of CORS_ORIGIN or CORS_ORIGINS must be set. NON-SECRET.
CORS_ORIGIN=
# CORS_ORIGINS — Alternative to CORS_ORIGIN: comma-separated list. Example: https://app.example.com,https://www.example.com. If both set, CORS_ORIGINS wins.
# CORS_ORIGINS=
# WS_PATH — Controls WebSocket path; must match ALB path. Example prod: /ws. NON-SECRET. Injected: EC2 env / PM2; ALB path must match.
WS_PATH=/ws

# Redis / Render Key Value
# For a one-instance project deploy, set DISABLE_REDIS=true to skip Redis.
# For multi-instance scaling, leave DISABLE_REDIS=false/blank and set REDIS_URL to Render Key Value's internal URL.
DISABLE_REDIS=true
# REDIS_URL=redis://<render-key-value-internal-host>:6379

# ----- Metrics protection (GET /metrics) -----
# METRICS_MODE — Optional: open | secret | admin | disabled. Default: production=secret, dev=open.
METRICS_MODE=secret
# METRICS_SECRET — Required in production when mode is secret. Header x-metrics-key must match. SECRET.
METRICS_SECRET=change-me-long-random
# METRICS_ENABLE_ADMIN_ROUTE — If true, GET /api/metrics is available for admin (cookie) debugging. Default false.
METRICS_ENABLE_ADMIN_ROUTE=false
# ALLOW_PUBLIC_METRICS_IN_PROD — If true, allows METRICS_MODE=open in production. Default false. Do not set unless intentional.
ALLOW_PUBLIC_METRICS_IN_PROD=false

# ALLOWED_ORIGINS — DEPRECATED/IGNORED. Use CORS_ORIGIN or CORS_ORIGINS (config/origins.js).
# ALLOWED_ORIGINS=

# Optional (behavioral defaults)
JWT_COOKIE_NAME=token
# HTTP_BODY_LIMIT — Express JSON/urlencoded body size limit (uploads are multipart via multer).
HTTP_BODY_LIMIT=256kb

# ===== Email config for password reset OTP =====
# Gmail local example:
# 1. Turn on Google 2-Step Verification.
# 2. Create a Gmail App Password.
# 3. Use the app password as SMTP_PASS. Do not use your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Thread <yourgmail@gmail.com>"
# Optional local-only test endpoint: POST /api/password/debug-mail { "email": "you@example.com" }
# Prefer CLI: TEST_EMAIL=you@example.com npm run mail:test
ENABLE_DEV_MAIL_ROUTE=false

# DEV-ONLY: Required for GET /api/dev/session. Must match VITE_DEV_SESSION_KEY in frontend. NOT USED IN PRODUCTION.
# DEV_SESSION_KEY=supersecret

# DEV-ONLY: When ENABLE_DEV_ROUTES=true, /api/dev/* routes are registered. Request must include header x-dev-key equal to this value (or DEV_SESSION_KEY). 404 if missing/wrong. NOT USED IN PRODUCTION.
# ENABLE_DEV_ROUTES=true
# DEV_ROUTES_KEY=your-secret-dev-key

# DEV-ONLY: When true, backend accepts x-dev-user header (API) and ?dev_user= query (WS) to bypass JWT. Set to true in dev if frontend uses VITE_DEV_BYPASS_AUTH=true. NEVER use in production.
# ALLOW_BYPASS_AUTH=true

# Database (stub) — dev/test only
# Set to true to simulate DB errors
SIMULATE_DB_ERROR=

# WebSocket — protocol
WS_PROTOCOL_VERSION=1.0.0

# WebSocket — rate limiting
WS_RATE_LIMIT_MESSAGES=100
WS_RATE_LIMIT_WINDOW_MS=60000
WS_RATE_LIMIT_WARNING_THRESHOLD=0.8
WS_VIOLATIONS_BEFORE_THROTTLE=2
WS_MAX_VIOLATIONS=5

# WebSocket — payload
WS_MAX_PAYLOAD_SIZE=1048576

# WebSocket — backpressure
WS_BACKPRESSURE_THRESHOLD=100
WS_BACKPRESSURE_MAX_QUEUE=200
WS_BACKPRESSURE_BUFFERED_THRESHOLD=1048576
WS_BACKPRESSURE_MAX_OVERFLOWS=5

# WebSocket — heartbeat
WS_HEARTBEAT_INTERVAL=30000
WS_HEARTBEAT_TIMEOUT=60000

# WebSocket — server
WS_SHUTDOWN_TIMEOUT=10000
WS_MAX_CONNECTIONS=0
WS_MAX_CONNECTIONS_PER_USER=5
WS_MAX_CONNECTIONS_PER_IP=50

# WebSocket — logging (level: debug, info, warn, error)
WS_LOG_LEVEL=info
WS_LOG_JSON=

# WebSocket — rooms
WS_MAX_ROOMS=0
WS_MAX_MEMBERS_PER_ROOM=0
WS_ROOM_AUTO_CREATE=true
WS_ROOM_AUTO_DELETE_EMPTY=true
WS_ROOM_LEAVE_ON_DISCONNECT=true
